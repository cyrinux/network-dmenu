# Network DMenu Configuration Example

dmenu_cmd = "dmenu"
dmenu_args = "--no-multi"
use_dns_cache = true

# nextdns_api_key = "your-api-key-here"
# nextdns_toggle_profiles = ["home-profile-id", "work-profile-id"]

# exclude_exit_node = ["exit1", "exit2"]
# max_nodes_per_country = 2
# max_nodes_per_city = 1
# country_filter = "USA"

[ssh_proxies]
# [ssh_proxies.example]
# name = "example"
# host = "example.com"
# user = "user"
# port = 1080
# remote_port = 22

[torsocks_apps]
# [torsocks_apps.firefox]
# name = "firefox"
# command = "firefox"
# args = ["--private-window"]
# description = "Firefox via Tor"

[[actions]]
display = "🛡️ Example"
cmd = "notify-send 'hello' 'world'"
