# Minimal Network DMenu Configuration
# Copy this to ~/.config/network-dmenu/config.toml and customize

dmenu_cmd = "dmenu"
dmenu_args = "-i -p 'Network:'"
use_dns_cache = true

[[actions]]
display = "📡 DNS: Use Cloudflare (1.1.1.1)"
cmd = "sudo resolvectl dns wlan0 1.1.1.1 1.0.0.1"

[[actions]]
display = "📡 DNS: Use DHCP default"
cmd = "sudo resolvectl revert wlan0"
